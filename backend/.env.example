# LLM-Guard 后端配置示例
# 复制本文件为 backend/.env 并填写真实值。.env 已被 .gitignore 忽略。

# 初始管理员账号（首次启动、数据库为空时创建一次）
# 若不提供，且在交互式终端启动，会提示手动输入；非交互式启动则拒绝启动。
# 密码至少 8 位。
LLM_GUARD_INITIAL_USERNAME=admin
LLM_GUARD_INITIAL_PASSWORD=change-this-strong-password

# 会话有效期（秒），默认 8 小时
# LLM_GUARD_SESSION_SECONDS=28800

# ---- OpenAI 兼容代理（可选）----
# 真实上游地址，必填才能启用 /v1 代理；不能指向内网/回环地址
# LLM_GUARD_PROXY_UPSTREAM=https://your-upstream/v1
# 脱敏模式：mask | placeholder | remove | report_only | off
# LLM_GUARD_PROXY_MODE=mask
# LLM_GUARD_PROXY_ENABLED=true
# 代理访问密钥：设置后，客户端必须用 Authorization: Bearer <此值> 才能访问 /v1/*
# LLM_GUARD_PROXY_API_KEY=
# 注入给上游的真实凭据（客户端的 Authorization 不会被转发）
# LLM_GUARD_PROXY_UPSTREAM_AUTHORIZATION=Bearer sk-your-real-upstream-key
